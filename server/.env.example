# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/bill-organizer
# Or for Atlas: mongodb+srv://user:pass@cluster.abc.mongodb.net/bill-organizer?retryWrites=true&w=majority

# Server
PORT=5000

# Firebase Admin SDK
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=
# OR set these individually:
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Cloudinary (image storage — preferred)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Or use the connection string: CLOUDINARY_URL=cloudinary://KEY:SECRET@CLOUD_NAME
