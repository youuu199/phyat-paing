# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/bill-organizer
# Or for Atlas: mongodb+srv://user:pass@cluster.abc.mongodb.net/bill-organizer?retryWrites=true&w=majority

# Server
PORT=5000

# Environment (development | production)
NODE_ENV=development

# Auth — JWT secret (change this in production!)
JWT_SECRET=your-jwt-secret-change-me

# OCR — Tesseract.js (FREE, no API keys required)
# Automatically downloads eng+mya language data on first run.

# Cohere AI
COHERE_API_KEY=your-cohere-api-key
# COHERE_MODEL=command-a-plus-05-2026  # Optional: override AI model

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS — Frontend URL (required in production)
FRONTEND_URL=http://localhost:5173

# Logging (fatal | error | warn | info | debug | trace)
LOG_LEVEL=debug

# MCP servers (used in .mcp.json)
MCP_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/bill-organizer?retryWrites=true&w=majority
MAGIC_API_KEY=sk-your-21st-dev-key
